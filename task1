<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>משימת חשבון מהירה ⚡</title>
    <script src="https://cdn.jsdelivr.net/npm/firebase@8.10.1/firebase-app.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/firebase@8.10.1/firebase-database.js"></script>
    <style>
        body { font-family: sans-serif; text-align: center; background: #f0f4f8; padding: 50px; }
        .card { background: white; padding: 30px; border-radius: 20px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); display: inline-block; }
        button { background: #1976d2; color: white; border: none; padding: 10px 20px; margin: 10px; border-radius: 10px; cursor: pointer; font-size: 1.1em; }
        button:hover { background: #1565c0; }
        #status { margin-top: 20px; font-weight: bold; color: #2e7d32; }
    </style>
</head>
<body>

<div class="card">
    <h2>משימת בונוס: כמה זה 12 כפול 4?</h2>
    <div id="options">
        <button onclick="checkAnswer(44)">44</button>
        <button onclick="checkAnswer(48)">48</button>
        <button onclick="checkAnswer(52)">52</button>
    </div>
    <div id="status"></div>
</div>

<script>
    // הגדרות ה-Firebase שלך (אותן הגדרות מהחווה)
    const firebaseConfig = {
        apiKey: "AIzaSyCtS0Gf9oNiRg6OTd3jyNaPxuWBFlWGIsE",
        authDomain: "liorfarm.firebaseapp.com",
        databaseURL: "https://liorfarm-default-rtdb.europe-west1.firebasedatabase.app",
        projectId: "liorfarm",
        storageBucket: "liorfarm.firebasestorage.app",
        messagingSenderId: "436063422896",
        appId: "1:436063422896:web:4cb14fbcc036ba97676e75"
    };
    firebase.initializeApp(firebaseConfig);
    const db = firebase.database();

    // קבלת ה-ID של התלמיד מהכתובת (למשל: task.html?uid=123)
    const urlParams = new URLSearchParams(window.location.search);
    const studentId = urlParams.get('uid');

    function checkAnswer(answer) {
        if (answer === 48) {
            document.getElementById('status').innerText = "כל הכבוד! מעדכן XP...";
            giveXP(50); // הענקת 50 XP
        } else {
            document.getElementById('status').innerText = "אופס, נסה שוב!";
            document.getElementById('status').style.color = "red";
        }
    }

    function giveXP(amount) {
        if (!studentId) return alert("שגיאה: לא נמצא מזהה תלמיד!");

        const studentRef = db.ref('students/' + studentId);
        studentRef.once('value').then((snapshot) => {
            const data = snapshot.val();
            let newXp = (data.xp || 0) + amount;
            let newLevel = data.level || 0;

            if (newXp >= 100) {
                newLevel++;
                newXp = 0;
            }

            studentRef.update({
                xp: newXp,
                level: newLevel
            }).then(() => {
                document.getElementById('status').innerText = "ה-XP עודכן! אפשר לחזור לחווה.";
                setTimeout(() => window.close(), 2000); // סוגר את הלשונית אחרי 2 שניות
            });
        });
    }
</script>
</body>
</html>
