<!DOCTYPE html>
<html lang="he">
<head>
  <meta charset="UTF-8">
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
</head>
<body>

<h2>בדיקת חווה</h2>
<div id="output"></div>

<script>
// 🔥 שים פה את הפרטים שלך
const SUPABASE_URL = 'https://YOUR_PROJECT.supabase.co';
const SUPABASE_KEY = 'YOUR_ANON_KEY';

const supabaseClient = supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

// טען תלמידים
async function loadStudents() {
  const { data, error } = await supabaseClient
    .from('students')
    .select('*');

  if (error) {
    console.error(error);
    alert('שגיאה בטעינה');
    return;
  }

  render(data);
}

// הצגה
function render(students) {
  const div = document.getElementById('output');
  div.innerHTML = '';

  students.forEach(s => {
    const el = document.createElement('div');
    el.innerHTML = `
      ${s.name} | XP: ${s.xp}
      <button onclick="addXP('${s.id}')">+10</button>
    `;
    div.appendChild(el);
  });
}

// עדכון XP
async function addXP(id) {
  const { data } = await supabaseClient
    .from('students')
    .select('*')
    .eq('id', id)
    .single();

  const newXP = (data.xp || 0) + 10;

  await supabaseClient
    .from('students')
    .update({ xp: newXP })
    .eq('id', id);

  loadStudents();
}

// התחלה
loadStudents();
</script>

</body>
</html>
